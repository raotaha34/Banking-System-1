@model BankingSystemweb.ViewModels.UserDashboardVM

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>SecureBank User Dashboard</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
    <link rel="stylesheet" href="~/css/userdashboard.css" asp-append-version="true" />
</head>
<body>
    <div class="db-shell">

        <!-- SIDEBAR -->
        <div class="sidebar" id="sidebar">
            <!-- Brand -->
            <div class="sb-brand">
                <div class="brand-mark"><i class="fas fa-shield-alt"></i></div>
                <span class="brand-text">SecureBank</span>
                <button class="sb-toggle" onclick="toggleSB()">
                    <i class="fas fa-bars"></i>
                </button>
            </div>

            <!-- Navigation -->
            <div class="sb-nav">
                <div class="nav-item active" data-label="Dashboard">
                    <div class="ni-icon"><i class="fas fa-home"></i></div>
                    <span class="ni-label">Dashboard</span>
                </div>

                <a class="nav-item" asp-controller="User" asp-action="UserInfo" data-label="View My Details">
                    <div class="ni-icon"><i class="fas fa-user-circle"></i></div>
                    <span class="ni-label">View My Details</span>
                </a>

                <a class="nav-item" asp-controller="User" asp-action="Transactions" data-label="Transaction">
                    <div class="ni-icon"><i class="fas fa-exchange-alt"></i></div>
                    <span class="ni-label">Transaction</span>
                </a>

                <a class="nav-item" asp-controller="User" asp-action="Recentactivity" data-label="Recent Activity">
                    <div class="ni-icon"><i class="fas fa-history"></i></div>
                    <span class="ni-label">Recent Activity</span>
                </a>

                <a class="nav-item" asp-controller="User" asp-action="TransactionHistroy" data-label="Transaction History">
                    <div class="ni-icon"><i class="fas fa-list-alt"></i></div>
                    <span class="ni-label">Transaction History</span>
                </a>

                <a class="nav-item" asp-controller="User" asp-action="Notification" data-label="Notification">
                    <div class="ni-icon"><i class="fas fa-bell"></i></div>
                    <span class="ni-label">Notification</span>
                </a>

                <a class="nav-item" asp-controller="User" asp-action="Forgetpassword" data-label="Forget Password">
                    <div class="ni-icon"><i class="fas fa-key"></i></div>
                    <span class="ni-label">Forget Password</span>
                </a>

                <div class="nav-item" data-label="Settings">
                    <div class="ni-icon"><i class="fas fa-cog"></i></div>
                    <span class="ni-label">Settings</span>
                </div>
            </div>

            <!-- Footer / Logout -->
            <div class="sb-footer">
                <form asp-controller="Login" asp-action="Logout" method="post">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="logout-btn">
                        <div class="lo-icon"><i class="fas fa-sign-out-alt"></i></div>
                        <span class="lo-label">Logout</span>
                    </button>
                </form>
            </div>
        </div>

        <!-- MAIN CONTENT -->
        <div class="main">
            <div class="container">

                <!-- Header -->
                <div class="header">
                    <div class="logo-section">
                        <div class="bank-icon"><i class="fas fa-shield-alt"></i></div>
                        <div class="bank-name">Secure Bank</div>
                    </div>
                    <div class="user-section">
                        <div class="user-info">
                            <div class="user-name">@Model.FullName</div>
                            <div class="user-id"></div>
                        </div>
                        <div class="user-avatar" id="heroAvatar"></div>
                    </div>
                </div>

                <!-- Account Summary -->
                <div class="account-summary">
                    <div class="summary-card">
                        <div class="card-header">
                            <div class="card-title">Total Balance</div>
                            <div class="card-icon icon-blue"><i class="fas fa-wallet"></i></div>
                        </div>
                        <div class="card-amount" id="totalBalance">
                            @Model.Accounts.Sum(a => a.Balance).ToString("N2")
                        </div>
                        <div class="card-detail">
                            <i class="fas fa-arrow-up positive"></i>
                            <span class="positive">+12.5%</span> from last month
                        </div>
                    </div>

                    <div class="summary-card">
                        <div class="card-header">
                            <div class="card-title">Total Deposit</div>
                            <div class="card-icon icon-green"><i class="fas fa-arrow-circle-down"></i></div>
                        </div>
                        <div class="card-amount" id="totalDeposit">
                            @ViewData["TodaysDeposits"]
                        </div>
                        <div class="card-detail">
                            <i class="fas fa-arrow-up positive"></i>
                            <span class="positive"></span> this month
                        </div>
                    </div>

                    <div class="summary-card">
                        <div class="card-header">
                            <div class="card-title">Total Withdraw</div>
                            <div class="card-icon icon-orange"><i class="fas fa-arrow-circle-up"></i></div>
                        </div>
                        <div class="card-amount" id="totalWithdraw">
                            @ViewData["TodaysWithdrawals"]
                        </div>
                        <div class="card-detail">
                            <i class="fas fa-arrow-down negative"></i>
                            <span class="negative">-</span> this month
                        </div>
                    </div>

                    <div class="summary-card">
                        <div class="card-header">
                            <div class="card-title">Total Transactions</div>
                            <div class="card-icon icon-purple"><i class="fas fa-exchange-alt"></i></div>
                        </div>
                        <div class="card-amount" id="totalTransactions">
                            @ViewData["Total Transaction"]
                        </div>
                        <div class="card-detail">
                            <i class="fas fa-arrow-up positive"></i>
                            <span class="positive"></span> this month
                        </div>
                    </div>
                </div>

                <!-- Quick Actions -->
                <div class="quick-actions">
                    <div class="section-title">Quick Actions</div>
                    <div class="actions-grid">
                        <a class="action-btn btn-back"asp-controller="User" asp-action="UserInfo">
                            <div class="action-icon"><i class="fas fa-user-circle"></i></div>
                            <div class="action-label">View My Details</div>
                        </a>
                        <a class="action-btn" asp-controller="User" asp-action="Transactions">
                            <div class="action-icon"><i class="fas fa-exchange-alt"></i></div>
                            <div class="action-label">Transaction</div>
                        </a>
                        <a class="action-btn" asp-controller="User" asp-action="Recentactivity">
                            <div class="action-icon"><i class="fas fa-history"></i></div>
                            <div class="action-label">Recent Activity</div>
                        </a>
                        <a class="action-btn" asp-controller="User" asp-action="TransactionHistroy">
                            <div class="action-icon"><i class="fas fa-list-alt"></i></div>
                            <div class="action-label">Transaction History</div>
                        </a>
                        <a class="action-btn" asp-controller="User" asp-action="Notification">
                            <div class="action-icon"><i class="fas fa-bell"></i></div>
                            <div class="action-label">Notifications</div>
                        </a>
                        <a class="action-btn" asp-controller="User" asp-action="Forgetpassword">
                            <div class="action-icon"><i class="fas fa-key"></i></div>
                            <div class="action-label">Change Password</div>
                        </a>
                    </div>
                </div>

                <!-- Services Section -->
                <div class="services-section">
                    <div class="service-card">
                        <div class="section-title">Banking Services</div>
                        <div class="service-item">
                            <div class="service-icon icon-blue"><i class="fas fa-university"></i></div>
                            <div class="service-info">
                                <div class="service-name">Account Management</div>
                                <div class="service-desc">View and manage all accounts</div>
                            </div>
                            <i class="fas fa-chevron-right service-arrow"></i>
                        </div>
                        <div class="service-item">
                            <div class="service-icon icon-green"><i class="fas fa-receipt"></i></div>
                            <div class="service-info">
                                <div class="service-name">Statements</div>
                                <div class="service-desc">Download bank statements</div>
                            </div>
                            <i class="fas fa-chevron-right service-arrow"></i>
                        </div>
                        <div class="service-item">
                            <div class="service-icon icon-orange"><i class="fas fa-cog"></i></div>
                            <div class="service-info">
                                <div class="service-name">Standing Instructions</div>
                                <div class="service-desc">Manage auto payments</div>
                            </div>
                            <i class="fas fa-chevron-right service-arrow"></i>
                        </div>
                        <div class="service-item">
                            <div class="service-icon icon-red"><i class="fas fa-lock"></i></div>
                            <div class="service-info">
                                <div class="service-name">Security Settings</div>
                                <div class="service-desc">Update passwords & 2FA</div>
                            </div>
                            <i class="fas fa-chevron-right service-arrow"></i>
                        </div>
                    </div>

                    <div class="service-card">
                        <div class="section-title">Cards & Payments</div>
                        <div class="service-item">
                            <div class="service-icon icon-blue"><i class="fas fa-credit-card"></i></div>
                            <div class="service-info">
                                <div class="service-name">Manage Cards</div>
                                <div class="service-desc">Block, activate or request new cards</div>
                            </div>
                            <i class="fas fa-chevron-right service-arrow"></i>
                        </div>
                        <div class="service-item">
                            <div class="service-icon icon-green"><i class="fas fa-shield-alt"></i></div>
                            <div class="service-info">
                                <div class="service-name">Card Security</div>
                                <div class="service-desc">Set limits and controls</div>
                            </div>
                            <i class="fas fa-chevron-right service-arrow"></i>
                        </div>
                        <div class="service-item">
                            <div class="service-icon icon-orange"><i class="fas fa-gift"></i></div>
                            <div class="service-info">
                                <div class="service-name">Rewards & Offers</div>
                                <div class="service-desc">View your rewards points</div>
                            </div>
                            <i class="fas fa-chevron-right service-arrow"></i>
                        </div>
                        <div class="service-item">
                            <div class="service-icon icon-red"><i class="fas fa-percentage"></i></div>
                            <div class="service-info">
                                <div class="service-name">EMI Calculator</div>
                                <div class="service-desc">Convert to easy installments</div>
                            </div>
                            <i class="fas fa-chevron-right service-arrow"></i>
                        </div>
                    </div>

                    <div class="service-card">
                        <div class="section-title">Additional Services</div>
                        <div class="service-item">
                            <div class="service-icon icon-blue"><i class="fas fa-plane"></i></div>
                            <div class="service-info">
                                <div class="service-name">Travel Insurance</div>
                                <div class="service-desc">Protect your travels</div>
                            </div>
                            <i class="fas fa-chevron-right service-arrow"></i>
                        </div>
                        <div class="service-item">
                            <div class="service-icon icon-green"><i class="fas fa-heartbeat"></i></div>
                            <div class="service-info">
                                <div class="service-name">Health Insurance</div>
                                <div class="service-desc">Medical coverage plans</div>
                            </div>
                            <i class="fas fa-chevron-right service-arrow"></i>
                        </div>
                        <div class="service-item">
                            <div class="service-icon icon-orange"><i class="fas fa-landmark"></i></div>
                            <div class="service-info">
                                <div class="service-name">Fixed Deposits</div>
                                <div class="service-desc">Earn higher interest rates</div>
                            </div>
                            <i class="fas fa-chevron-right service-arrow"></i>
                        </div>
                        <div class="service-item">
                            <div class="service-icon icon-red"><i class="fas fa-bell"></i></div>
                            <div class="service-info">
                                <div class="service-name">Alerts & Notifications</div>
                                <div class="service-desc">Manage transaction alerts</div>
                            </div>
                            <i class="fas fa-chevron-right service-arrow"></i>
                        </div>
                    </div>
                </div>

                <!-- Recent Transactions -->
                <div class="transactions-table">
                    <div class="section-title">Recent Transactions</div>
                    <table>
                        <thead>
                            <tr>
                                <th>Date</th>
                                <th>Description</th>
                                <th>Type</th>
                                <th>Amount</th>
                                <th>Status</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr>
                                <td>Dec 10, 2024</td>
                                <td><span class="transaction-icon icon-green"><i class="fas fa-arrow-down"></i></span>Salary Credit - ABC Corp</td>
                                <td>Credit</td>
                                <td style="color:#10b981;font-weight:600">+$5,250.00</td>
                                <td><span class="status-badge status-completed">Completed</span></td>
                            </tr>
                            <tr>
                                <td>Dec 09, 2024</td>
                                <td><span class="transaction-icon icon-orange"><i class="fas fa-shopping-cart"></i></span>Amazon Purchase</td>
                                <td>Debit</td>
                                <td style="color:#ef4444;font-weight:600">-$129.99</td>
                                <td><span class="status-badge status-completed">Completed</span></td>
                            </tr>
                            <tr>
                                <td>Dec 08, 2024</td>
                                <td><span class="transaction-icon icon-blue"><i class="fas fa-exchange-alt"></i></span>Transfer to John Doe</td>
                                <td>Transfer</td>
                                <td style="color:#ef4444;font-weight:600">-$500.00</td>
                                <td><span class="status-badge status-completed">Completed</span></td>
                            </tr>
                            <tr>
                                <td>Dec 07, 2024</td>
                                <td><span class="transaction-icon icon-red"><i class="fas fa-bolt"></i></span>Electricity Bill Payment</td>
                                <td>Bill Payment</td>
                                <td style="color:#ef4444;font-weight:600">-$85.50</td>
                                <td><span class="status-badge status-pending">Pending</span></td>
                            </tr>
                            <tr>
                                <td>Dec 06, 2024</td>
                                <td><span class="transaction-icon icon-orange"><i class="fas fa-utensils"></i></span>Restaurant - Olive Garden</td>
                                <td>Debit</td>
                                <td style="color:#ef4444;font-weight:600">-$67.25</td>
                                <td><span class="status-badge status-completed">Completed</span></td>
                            </tr>
                        </tbody>
                    </table>
                </div>

            </div>
        </div>
    </div>

    <script>
    
        const avatarColors = {
            A:'#E53E3E',B:'#DD6B20',C:'#D69E2E',D:'#38A169',E:'#319795',
            F:'#3182CE',G:'#805AD5',H:'#D53F8C',I:'#E53E3E',J:'#2B6CB0',
            K:'#D69E2E',L:'#38A169',M:'#319795',N:'#3182CE',O:'#805AD5',
            P:'#D53F8C',Q:'#E53E3E',R:'#C05621',S:'#2F855A',T:'#2C7A7B',
            U:'#2B6CB0',V:'#6B46C1',W:'#97266D',X:'#C53030',Y:'#744210',Z:'#1A365D'
        };

        function getInitials(name) {
            if (!name) return 'U';
            const parts = name.trim().split(/\s+/);
            return parts.length >= 2
                ? (parts[0][0] + parts[1][0]).toUpperCase()
                : parts[0][0].toUpperCase();
        }

        function getColor(name) {
            if (!name) return '#6B7280';
            const c = name.trim()[0].toUpperCase();
            return avatarColors[c] || '#6B7280';
        }

        document.addEventListener('DOMContentLoaded', function() {
            const fullName = '@(Model.FullName ?? "")';
            const initials = getInitials(fullName);
            const color = getColor(fullName);

            const heroAvatar = document.getElementById('heroAvatar');
            if (heroAvatar) {
                heroAvatar.textContent = initials;
                heroAvatar.style.background = color;
            }
        });

             function animateCounter(id, duration = 1500) {
            const element = document.getElementById(id);
            if (!element) return;

            // Parse numeric value, remove any formatting
            const target = parseFloat(element.innerText.replace(/[^0-9.-]+/g, '')) || 0;
            let start = 0;
            const increment = target / (duration / 16); // approx 60fps

            function update() {
                start += increment;
                if (start >= target) {
                    // Keep decimals if needed
                    if (element.innerText.includes(".")) {
                        element.innerText = target.toLocaleString(undefined, { minimumFractionDigits: 2, maximumFractionDigits: 2 });
                    } else {
                        element.innerText = Math.floor(target).toLocaleString();
                    }
                } else {
                    if (element.innerText.includes(".")) {
                        element.innerText = start.toLocaleString(undefined, { minimumFractionDigits: 2, maximumFractionDigits: 2 });
                    } else {
                        element.innerText = Math.floor(start).toLocaleString();
                    }
                    requestAnimationFrame(update);
                }
            }
            update();
        }
		//sidebar toggle
              const sidebar = document.getElementById('sidebar');
        function toggleSB() {
            sidebar.classList.toggle('collapsed');
            document.querySelector('.main-content').classList.toggle('wide');
        }
        document.addEventListener("DOMContentLoaded", function() {
            animateCounter('totalBalance', 1500);
            animateCounter('totalDeposit', 1500);
            animateCounter('totalWithdraw', 1500);
            animateCounter('totalTransactions', 1500);
        });
    </script>
</body>
</html>