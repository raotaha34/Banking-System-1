@model BankingSystemweb.ViewModels.UserDashboardVM

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>User Details</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
    <link rel="stylesheet" href="~/css/userinfo.css" asp-append-version="true" />
</head>

<body>
    <div class="page-wrapper">

        <!-- TOPBAR -->
        <div class="topbar">
            <div class="topbar-left">
                <div class="page-heading">User Details</div>
                <span class="breadcrumb">/ @Model.FullName</span>
            </div>
            <a asp-controller="User" asp-action="Index" class="btn-back">
                <i class="fas fa-arrow-left"></i> Back
            </a>
        </div>

        <!-- PROFILE -->
        <div class="profile-card">
            <div class="profile-avatar"id="heroAvatar"> </div>

            <div class="profile-info">
                <div class="profile-name">@Model.FullName</div>
                <div class="profile-username">@Model.UserName</div>

                <div class="profile-meta">
                    <div class="meta-item">
                        <i class="fas fa-envelope"></i>
                        <span>@Model.Email</span>
                    </div>

                    <div class="meta-item">
                        <i class="fas fa-circle" style="color:#10b981;font-size:8px;"></i>
                        <span>
                            @Model.Accounts.Count(a => a.Status == "Active") Active Accounts
                        </span>
                    </div>
                </div>
            </div>
        </div>

        <!-- STAT STRIP -->
        <div class="stat-strip">

            <div class="stat-card">
                <div class="stat-icon blue"><i class="fas fa-wallet"></i></div>
                <div>
                    <div class="stat-label">Total Balance</div>
                    <div class="stat-value" id="stat-total-balance">
                        $@Model.Accounts.Sum(a => a.Balance).ToString("N2")
                    </div>
                </div>
            </div>

            <div class="stat-card">
                <div class="stat-icon green"><i class="fas fa-university"></i></div>
                <div>
                    <div class="stat-label">Total Accounts</div>
                    <div class="stat-value" id="stat-total-accounts">@Model.Accounts.Count</div>
                </div>
            </div>

            <div class="stat-card">
                <div class="stat-icon orange"><i class="fas fa-check-circle"></i></div>
                <div>
                    <div class="stat-label">Active Accounts</div>
                    <div class="stat-value" id="stat-active-accounts">
                        @Model.Accounts.Count(a => a.Status == "Active")
                    </div>
                </div>
            </div>

            <div class="stat-card">
                <div class="stat-icon purple"><i class="fas fa-percentage"></i></div>
                <div>
                    <div class="stat-label">Avg Interest</div>
                    <div class="stat-value" id="stat-avg-interest">
                        @{
                            var rates = Model.Accounts.Where(a => a.InterestRate.HasValue);
                            var avg = rates.Any() ? rates.Average(a => a.InterestRate!.Value) : 0;
                        }
                        @avg.ToString("0.00")%
                    </div>
                </div>
            </div>

        </div>

        <!-- ACCOUNT DETAILS -->
        <div class="section-heading">
            <i class="fas fa-id-card"></i> Account Details
        </div>

        <div class="table-wrap">
            <table>
                <thead>
                    <tr>
                        <th>Account No</th>
                        <th>Type</th>
                        <th>Status</th>
                        <th>Balance</th>
                        <th>Interest</th>
                        <th>Opening Date</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var acc in Model.Accounts)
                    {
                        <tr>
                            <td>@acc.AccountNumber</td>
                            <td>@acc.AccountType</td>
                            <td>@acc.Status</td>
                            <td>$@acc.Balance.ToString("N2")</td>
                            <td>
                                @(acc.InterestRate.HasValue
                                                            ? acc.InterestRate.Value.ToString("0.00") + "%" 
                                                                    : "N/A")
                            </td>
                            <td>@acc.OpeningDate.ToString("MMM dd, yyyy")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

    </div>

    <script>

            // Animate number counting from 0 to target
        function animateCounter(id, duration = 1500, isCurrency = false, isPercent = false) {
            const el = document.getElementById(id);
            if (!el) return;

            let text = el.innerText.replace(/[^0-9.]+/g, '');
            let target = parseFloat(text) || 0;
            let start = 0;
            const increment = target / (duration / 16); // approx 60fps

            function update() {
                start += increment;
                if (start >= target) {
                    el.innerText = formatValue(target);
                } else {
                    el.innerText = formatValue(start);
                    requestAnimationFrame(update);
                }
            }

            function formatValue(val) {
                let formatted = Math.floor(val).toLocaleString();
                if (isCurrency) formatted = '$' + formatted;
                if (isPercent) formatted = val.toFixed(2) + '%';
                return formatted;
            }

            update();
        }

        document.addEventListener("DOMContentLoaded", function() {
            animateCounter('stat-total-balance', 1500, true);     // $ currency
            animateCounter('stat-total-accounts', 1000);          // plain number
            animateCounter('stat-active-accounts', 1000);         // plain number
            animateCounter('stat-avg-interest', 1500, false, true); // percent
        });
        const avatarColors = {
            A:'#E53E3E',B:'#DD6B20',C:'#D69E2E',D:'#38A169',E:'#319795',
            F:'#3182CE',G:'#805AD5',H:'#D53F8C',I:'#E53E3E',J:'#2B6CB0',
            K:'#D69E2E',L:'#38A169',M:'#319795',N:'#3182CE',O:'#805AD5',
            P:'#D53F8C',Q:'#E53E3E',R:'#C05621',S:'#2F855A',T:'#2C7A7B',
            U:'#2B6CB0',V:'#6B46C1',W:'#97266D',X:'#C53030',Y:'#744210',Z:'#1A365D'
        };

        function getInitials(name) {
            if (!name) return 'U';
            const parts = name.trim().split(/\s+/);
            return parts.length >= 2
                ? (parts[0][0] + parts[1][0]).toUpperCase()
                : parts[0][0].toUpperCase();
        }

        function getColor(name) {
            if (!name) return '#6B7280';
            const c = name.trim()[0].toUpperCase();
            return avatarColors[c] || '#6B7280';
        }

        // 🔐 Razor-safe value
        const fullName = '@(Model.FullName ?? "")';

        const initials = getInitials(fullName);
        const color = getColor(fullName);

        const heroAvatar = document.getElementById('heroAvatar');

        if (heroAvatar) {
            heroAvatar.textContent = initials;
            heroAvatar.style.background = color;
        }



    </script>

</body>
</html>