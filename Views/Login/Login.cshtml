@model LoginViewModel

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title > Login page </title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <!-- Stylesheet -->
    <link rel="stylesheet" href="~/css/Login.css" asp-append-version="true" />
    <!-- Bootstrap -->
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />

    <!-- Extended Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?
family=Playfair+Display:wght@400;500;600;700;800;900&
family=Inter:wght@200;300;400;500;600;700;800;900&
family=Poppins:wght@300;400;500;600;700&
family=Roboto:wght@300;400;500;700&
display=swap" rel="stylesheet">

    <!-- Font Awesome (Latest 6.x with more icons support) -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" />

    <!-- Bootstrap Icons (Extra Icon Library) -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">

    <!-- Remix Icons (Modern UI Icons) -->
    <link href="https://cdn.jsdelivr.net/npm/remixicon@4.2.0/fonts/remixicon.css" rel="stylesheet">
    <!-- Font Awesome (for icons to work) -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
</head>
<body>

    <div class="container">
        <!-- Left Section with Image -->
        <div class="left-section">
            <div class="logo-section">
                <div class="logo">
                    <div class="logo-icon">
                        <i class="fas fa-landmark"></i>
                    </div>
                    <div class="logo-text">SecureBank</div>
                </div>
            </div>

            <div class="hero-content">
                <h1>Banking Reimagined for the Modern Age</h1>
                <p>Experience seamless, secure, and intelligent banking that adapts to your lifestyle. Join thousands who trust us with their financial future.</p>

                <div class="features">
                    <div class="feature-item">
                        <div class="feature-icon"><i class="fas fa-check"></i></div>
                        <span>Military-grade 256-bit encryption</span>
                    </div>
                    <div class="feature-item">
                        <div class="feature-icon"><i class="fas fa-check"></i></div>
                        <span>24/7 Real-time fraud monitoring</span>
                    </div>
                    <div class="feature-item">
                        <div class="feature-icon"><i class="fas fa-check"></i></div>
                        <span>Instant transfers worldwide</span>
                    </div>
                </div>
            </div>

            <div class="stats-section">
                <div class="stat">
                    <div class="stat-number">500K+</div>
                    <div class="stat-label">Active Users</div>
                </div>
                <div class="stat">
                    <div class="stat-number">$2.5B</div>
                    <div class="stat-label">Secured Daily</div>
                </div>
                <div class="stat">
                    <div class="stat-number">99.9%</div>
                    <div class="stat-label">Uptime</div>
                </div>
            </div>
        </div>
      
        <!-- Right Section with Form -->
        <div class="right-section">
            <div class="form-container">
                <div class="form-header">
                    <h2 class="form-title">Welcome Back</h2>
                    <p class="form-subtitle">Please enter your credentials to access your account</p>
                </div>


                 <form id="loginForm"  asp-action="Login" method="post">
                    <!-- Email Field -->
                    <div class="form-group">
                        <label class="form-label">Email Address</label>
                        <div class="input-wrapper">
                            <input class="form-input" name="Email" placeholder="your.email@example.com" />
                    <span asp-validation-for="Email" class="text-danger"></span>
                            <i class="fas fa-envelope input-icon"></i>
                        </div>
                    </div>
                   
                    
       

                    <!-- Password Field -->
                    <div class="form-group">
                        <label class="form-label">Password</label>
                        <div class="input-wrapper">
                    <input class="form-input" asp-for="Password" type="password" name="Password" placeholder="Enter your password" />
                            <span asp-validation-for="Password" class="text-danger"></span>
                            <i class="fas fa-lock input-icon"></i>
                            <button type="button" class="password-toggle" onclick="togglePassword()">
                                <i class="fas fa-eye" id="toggleIcon"></i>
                            </button>
                        </div>
                    </div>

                    <!-- Remember Me & Forgot Password -->
                    <div class="form-options">
                        <div class="checkbox-wrapper">
                            <input type="checkbox" class="custom-checkbox" id="rememberMeCheckbox" />
                            <label for="rememberMeCheckbox" class="checkbox-label">Remember me</label>
                        </div>
                        <a href="#" class="forgot-link">Forgot Password?</a>
                    </div>

                    <!-- Submit Button -->
                    <button type="submit" class="submit-btn">
                        <span class="btn-text">Sign In </span>
                    </button>
                    
                    <!-- Sign Up Link -->
                    <div class="signup-link">
                        Don't have an account? <a href="#">Sign up for free</a>
                    </div>
                </form>
            </div>

            <!-- Security Badge -->
            <div class="security-badge">
                <i class="fas fa-shield-alt security-icon"></i>
                <span>SSL Secured Connection</span>
            </div>
        </div>
    </div>

</body>
</html>