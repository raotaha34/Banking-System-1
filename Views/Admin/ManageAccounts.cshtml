@model IEnumerable<BankingSystemweb.ViewModels.UserListVM>

@{
    var usersJson = System.Text.Json.JsonSerializer.Serialize(Model);
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ManageUser</title>
    <link rel="stylesheet" href="~/css/manageuser.css">
    <style>
        .action-btns {
            display: flex;
            gap: 8px;
            align-items: center;
        }

        .btn-action {
            display: inline-flex;
            align-items: center;
            gap: 5px;
            padding: 6px 14px;
            border-radius: 6px;
            font-size: 13px;
            font-weight: 500;
            cursor: pointer;
            border: none;
            text-decoration: none;
            transition: opacity 0.2s;
        }

            .btn-action:hover {
                opacity: 0.85;
            }

        .btn-edit {
            background: #EFF6FF;
            color: #2563EB;
        }

        .btn-delete {
            background: #FEF2F2;
            color: #DC2626;
        }

            .btn-edit svg,
            .btn-delete svg {
                width: 14px;
                height: 14px;
                stroke-width: 2;
                flex-shrink: 0;
            }

        /* Topbar Create Button fix */
        .topbar-right .btn-create {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            padding: 8px 18px;
            background: #2563EB;
            color: #fff;
            border-radius: 8px;
            font-size: 14px;
            font-weight: 600;
            text-decoration: none;
            cursor: pointer;
            border: none;
        }

            .topbar-right .btn-create svg {
                width: 16px;
                height: 16px;
                stroke: #fff;
                stroke-width: 2;
                fill: none;
            }

            .topbar-right .btn-create:hover {
                background: #1D4ED8;
            }

        /* toast */ /* Toast */
        .toast {
            position: fixed;
            top: 30px; /* top-right corner */
            right: 30px;
            width: 280px; /* fixed width */
            max-width: 90vw; /* responsive */
            padding: 8px 16px; /* slightly smaller padding */
            border-radius: 8px;
            font-size: 14px;
            color: #fff;
            background: #1e293b; /* default dark */
            opacity: 0;
            pointer-events: none;
            transition: opacity 0.3s, background 0.3s;
            z-index: 9999;
            display: inline-block; /* compact height */
            line-height: 1.3; /* tighter spacing */
            box-sizing: border-box;
            word-wrap: break-word; /* wrap long messages */
            white-space: normal; /* allow multiple lines */
            max-height: 60px; /* shorter max height */
            overflow: hidden; /* clip extra text if too long */
        }

            /* Show toast */
            .toast.show {
                opacity: 1;
            }

        /* Success and error variants */
        .toast-success {
            background-color: #16a34a; /* green */
        }

        .toast-error {
            background-color: #dc2626; /* red */
        }


        .btn-dashboard {
            display: inline-flex;
            align-items: end;
            gap: 7px;
            padding: 8px 18px;
            background: #eef4ff;
            color: #1a6ef5;
            border: 1px solid #c2d9fc;
            border-radius: 8px;
            font-size: 13px;
            font-weight: 600;
            text-decoration: none;
            transition: background 0.18s, color 0.18s, border-color 0.18s;
            font-family: inherit;
            line-height: 1;
        }

            .btn-dashboard:hover {
                background: #1a6ef5;
                color: #ffffff;
                border-color: #1a6ef5;
            }

        .role-badge {
            padding: 4px 10px;
            border-radius: 12px;
            font-size: 12px;
            font-weight: 600;
        }

        /* Admin = light red */
        .role-admin {
            background: #FEE2E2;
            color: #DC2626;
        }

        /* User = light blue */
        .role-user {
            background: #DBEAFE;
            color: #2563EB;
        }

        /* Customer = light orange */
        .role-customer {
            background: #FFEDD5;
            color: #EA580C;
        }
    </style>
</head>
<body>
    @Html.AntiForgeryToken()

    <div class="topbar">
        <div class="topbar-left">
            <div class="logo-icon">
                <svg viewBox="0 0 24 24"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2" /><circle cx="9" cy="7" r="4" /><path d="M23 21v-2a4 4 0 0 0-3-3.87" /><path d="M16 3.13a4 4 0 0 1 0 7.75" /></svg>
            </div>
            <span class="page-title">User Management</span>
            <span class="breadcrumb">/ Users</span>
        </div>
        <div class="topbar-right">
            <a class="btn-dashboard" asp-controller="Admin" asp-action="Index">
                <svg width="14" height="14" viewBox="0 0 16 16" fill="none">
                    <rect x="1" y="1" width="6" height="6" rx="1.5" stroke="currentColor" stroke-width="1.5" />
                    <rect x="9" y="1" width="6" height="6" rx="1.5" stroke="currentColor" stroke-width="1.5" />
                    <rect x="1" y="9" width="6" height="6" rx="1.5" stroke="currentColor" stroke-width="1.5" />
                    <rect x="9" y="9" width="6" height="6" rx="1.5" stroke="currentColor" stroke-width="1.5" />
                </svg>
                Dashboard
            </a>
            <a class="btn-dashboard" asp-controller="Admin" asp-action="CreateUserAccount">
                @* <svg viewBox="0 0 24 24"><line x1="12" y1="5" x2="12" y2="19" /><line x1="5" y1="12" x2="19" y2="12" /></svg> *@
                <svg viewBox="0 0 24 24" width="14" height="14" fill="none">
                    <path d="M16 21v-2a4 4 0 00-4-4H6a4 4 0 00-4 4v2" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" />
                    <circle cx="9" cy="7" r="4" stroke="currentColor" stroke-width="1.8" />
                    <line x1="19" y1="8" x2="19" y2="14" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" />
                    <line x1="16" y1="11" x2="22" y2="11" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" />
                </svg>
                Create User
            </a>
        </div>
    </div>

    <div class="content">
        <div class="stats-row">
            <div class="stat-card">
                <div class="stat-icon" style="background:#EFF6FF;">
                    <svg viewBox="0 0 24 24" fill="none" stroke="#2563EB" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2" /><circle cx="9" cy="7" r="4" /><path d="M23 21v-2a4 4 0 0 0-3-3.87" /><path d="M16 3.13a4 4 0 0 1 0 7.75" /></svg>
                </div>
                <div><div class="stat-label">Total Users</div><div class="stat-value" id="s-total">@ViewData["TotalUsers"]</div></div>
            </div>
            <div class="stat-card">
                <div class="stat-icon" style="background:#F0FDF4;">
                    <svg viewBox="0 0 24 24" fill="none" stroke="#16A34A" stroke-width="2"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14" /><polyline points="22 4 12 14.01 9 11.01" /></svg>
                </div>
                <div><div class="stat-label">Active</div><div class="stat-value" id="s-active" style="color:#16A34A;">@ViewData["TotalActiveUsers"]</div></div>
            </div>
            <div class="stat-card">
                <div class="stat-icon" style="background:#FFF7ED;">
                    <svg viewBox="0 0 24 24" fill="none" stroke="#EA580C" stroke-width="2"><circle cx="12" cy="12" r="10" /><line x1="12" y1="8" x2="12" y2="12" /><line x1="12" y1="16" x2="12.01" y2="16" /></svg>
                </div>
                <div><div class="stat-label">Inactive</div><div class="stat-value" id="s-inactive" style="color:#EA580C;">@ViewData["TotalInactiveUsers"]</div></div>
            </div>
            <div class="stat-card">
                <div class="stat-icon" style="background:#F5F3FF;">
                    <svg viewBox="0 0 24 24" fill="none" stroke="#7C3AED" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" /></svg>
                </div>
                <div><div class="stat-label">Admins</div><div class="stat-value" id="s-admins" style="color:#7C3AED;">@ViewData["TotalAdmins"]</div></div>
            </div>
        </div>

        <div class="panel">
            <div class="panel-header">
                <div>
                    <div class="panel-title">User Directory</div>
                    <div class="panel-sub">Manage all registered system users</div>
                </div>
            </div>
            <div class="panel-body">
                <div class="search-filter-bar">
                    <div class="search-wrap">
                        <svg viewBox="0 0 24 24"><path d="M21 21l-4.35-4.35M17 11A6 6 0 1 1 5 11a6 6 0 0 1 12 0z" /></svg>
                        <input type="text" class="search-input" id="search-input" placeholder="Search by name or email...">
                    </div>
                    <select class="filter-select" id="filter-status">
                        <option value="">All Status</option>
                        <option value="Active">Active</option>
                        <option value="Inactive">Inactive</option>
                    </select>
                    <select class="filter-select" id="filter-role">
                        <option value="">All Roles</option>
                        <option value="Admin">Admin</option>
                        <option value="User">User</option>
                        <option value="Customer">Customer</option>
                    </select>
                </div>

                <table class="users-table">
                    <thead>
                        <tr>
                            <th>User</th>
                            <th>Role</th>
                            <th>Email</th>
                            <th>Status</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody id="users-body">
                    </tbody>
                </table>

                <div class="pagination">
                    <div id="page-info"></div>
                    <div id="page-btns" class="page-btns"></div>
                </div>
            </div>
        </div>
    </div>

    <!-- Toast -->
    <div id="toast" class="toast"></div>


    <script>
        let users = @Html.Raw(usersJson);

        const PER_PAGE = 10;
        let currentPage = 1;

        const csrfToken = document.querySelector('input[name="__RequestVerificationToken"]')?.value || '';

        function getFiltered() {
            const q = document.getElementById('search-input').value.toLowerCase();
            const st = document.getElementById('filter-status').value;
            const rl = document.getElementById('filter-role').value;
            return users.filter(u => {
                if (q && !((u.FullName + ' ' + u.Email).toLowerCase().includes(q))) return false;
                if (st && u.Status !== st) return false;
                        if (rl) {
            const mappedRole =
                u.Role === 'Admin' ? 'Admin' :
                (u.Role === 'Manager' || u.Role === 'User') ? 'User' :
                (u.Role === 'Viewer' || u.Role === 'Customer') ? 'Customer' :
            u.Role;

            if (mappedRole !== rl) return false;
        }
                return true;
            });
        }

        function renderTable() {
            const filtered = getFiltered();
            const total = filtered.length;
            const totalPages = Math.max(1, Math.ceil(total / PER_PAGE));
            if (currentPage > totalPages) currentPage = totalPages;

            const start = (currentPage - 1) * PER_PAGE;
            const page = filtered.slice(start, start + PER_PAGE);

            const tbody = document.getElementById('users-body');
            tbody.innerHTML = page.map(u => `
                <tr>
                    <td>
                        <div class="user-cell">
                             <div class="user-avatar" style="background:${getAvatarColor(u.FullName)}">
                               ${u.FullName[0].toUpperCase()}
                               </div>
                            <div>
                                <div class="user-name">${u.FullName}</div>
                                <div class="user-email">${u.Email}</div>
                            </div>
                        </div>
                    </td>
                    <td>
                  <span class="role-badge ${
                      u.Role === 'Admin' ? 'role-admin' :
                      (u.Role === 'Manager' || u.Role === 'User') ? 'role-user' :
                      (u.Role === 'Viewer' || u.Role === 'Customer') ? 'role-customer' :
                      'role-user'
                   }">
                     ${
                         u.Role === 'Admin' ? 'Admin' :
                         (u.Role === 'Manager' || u.Role === 'User') ? 'User' :
                         (u.Role === 'Viewer' || u.Role === 'Customer') ? 'Customer' :
                          u.Role
                    }
                 </span>
                    </td>
                    <td>${u.Email}</td>
                    <td>
                        <span class="status-dot">
                            <span class="dot ${u.Status === 'Active' ? 'dot-green' : 'dot-grey'}"></span>
                            <span class="${u.Status === 'Active' ? 'status-active' : 'status-inactive'}">
                                ${u.Status}
                            </span>
                        </span>
                    </td>
                    <td class="action-btns">
                          <a class="btn-action btn-edit"href="/Admin/EditUser/${u.Id}"title="Edit User">
                            <svg viewBox="0 0 24 24" fill="none" stroke="#2563EB">
                                <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/>
                                <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/>
                            </svg>
                            Edit
                        </a>
                        <button class="btn-action btn-delete" onclick="deleteUser('${u.Id}')">
                            <svg viewBox="0 0 24 24" fill="none" stroke="#DC2626">
                                <polyline points="3 6 5 6 21 6"/>
                                <path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/>
                                <path d="M10 11v6M14 11v6"/>
                                <path d="M9 6V4a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1v2"/>
                            </svg>
                            Delete
                        </button>
                    </td>
                </tr>
            `).join('');

            document.getElementById('page-info').textContent = total
                ? `Showing ${start + 1}-${Math.min(start + PER_PAGE, total)} of ${total} users`
                : 'No results found';

            const pb = document.getElementById('page-btns');
            pb.innerHTML = '';
            for (let i = 1; i <= totalPages; i++) {
                const btn = document.createElement('div');
                btn.className = 'page-btn' + (i === currentPage ? ' active' : '');
                btn.textContent = i;
                btn.onclick = () => { currentPage = i; renderTable(); };
                pb.appendChild(btn);
            }
        }

        function deleteUser(id) {
            if (confirm("Are you sure you want to delete this user?")) {
                fetch(`/Admin/DeleteUser/${id}`, {
                    method: 'POST',
                    headers: {
                        'RequestVerificationToken': csrfToken
                    }
                })
                .then(res => {
                           if (res.ok) {
                         users = users.filter(u => u.Id !== id);
                         renderTable();
                           showToast("User deleted successfully.", 'success'); // GREEN
                         } else {
                              showToast("Failed to delete user.", 'error');       // RED
                  }
                })
                .catch(() => showToast("Network error. Please try again."));
            }
        }


        // getAtarColor column

        function getAvatarColor(name) {
            const colors = [
                "#F87171", "#FBBF24", "#34D399",
                "#60A5FA", "#A78BFA", "#F472B6",
                "#22D3EE", "#FB923C", "#4ADE80",
                "#C084FC"
            ];

            const firstChar = name.charAt(0).toUpperCase();
            const index = firstChar.charCodeAt(0) % colors.length;

            return colors[index];
        }


        function showToast(msg,type = 'success') {
            const t = document.getElementById('toast');
            t.textContent = msg;
                // Remove previous type classes
        t.classList.remove('toast-success', 'toast-error');

        // Add new type class
        if (type === 'success') t.classList.add('toast-success');
        else if (type === 'error') t.classList.add('toast-error');

        // Show the toast
        t.classList.add('show');

        // Hide after 3 seconds
        setTimeout(() => t.classList.remove('show'), 3000);
        }

        document.getElementById('search-input').addEventListener('input', () => { currentPage = 1; renderTable(); });
        document.getElementById('filter-status').addEventListener('change', () => { currentPage = 1; renderTable(); });
        document.getElementById('filter-role').addEventListener('change', () => { currentPage = 1; renderTable(); });

        renderTable();

    </script>
</body>
</html>