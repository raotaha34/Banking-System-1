@model BankingSystemweb.ViewModels.CreateUserAccountVM

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Create Account — SecureBank</title>
    <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;500;600;700;800&family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;1,9..40,400&display=swap" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.css" rel="stylesheet" />
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.6.0/jquery.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validate/1.19.5/jquery.validate.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validation-unobtrusive/3.2.12/jquery.validate.unobtrusive.min.js"></script>
     <link rel="stylesheet" href="~/css/account.css" />
</head>
<body>

    <!-- ══════════ SIDEBAR ══════════ -->
    <aside class="sidebar" id="sidebar">

        <div class="sb-brand">
            <div class="brand-mark">
                <svg width="18" height="18" viewBox="0 0 20 20" fill="none">
                    <path d="M10 2L3 5v5c0 4.418 3.134 7.979 7 8 3.866-.021 7-3.582 7-8V5L10 2z" fill="white" fill-opacity=".9" />
                    <rect x="8.5" y="9" width="3" height="4" rx="1" fill="#2563eb" />
                    <circle cx="10" cy="9" r="1.5" fill="#2563eb" />
                </svg>
            </div>
            <span class="brand-text">SecureBank</span>
            <div class="sb-toggle" id="sbToggle">
                <svg width="10" height="10" viewBox="0 0 12 12" fill="none">
                    <path d="M7.5 2L3.5 6L7.5 10" stroke="#64748b" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" />
                </svg>
            </div>
        </div>

        <nav class="sb-nav">

            <div class="nav-section-label">Overview</div>
            <a class="nav-item active" asp-controller="Admin" asp-action="Index">
                <span class="ni-icon">
                    <svg width="15" height="15" viewBox="0 0 16 16" fill="none">
                        <rect x="1" y="1" width="6" height="6" rx="1.5" stroke="currentColor" stroke-width="1.5" />
                        <rect x="9" y="1" width="6" height="6" rx="1.5" stroke="currentColor" stroke-width="1.5" />
                        <rect x="1" y="9" width="6" height="6" rx="1.5" stroke="currentColor" stroke-width="1.5" />
                        <rect x="9" y="9" width="6" height="6" rx="1.5" stroke="currentColor" stroke-width="1.5" />
                    </svg>
                </span>
                <span class="ni-label">Dashboard</span>
                <span class="ni-tip">Dashboard</span>
            </a>

            <div class="nav-section-label">Users</div>
            <a class="nav-item" asp-controller="Admin" asp-action="CreateUserAccount">
                <span class="ni-icon">
                    <svg width="15" height="15" viewBox="0 0 16 16" fill="none">
                        <circle cx="7" cy="5" r="3" stroke="currentColor" stroke-width="1.5" />
                        <path d="M1 13c0-3 2.686-4.5 6-4.5s6 1.5 6 4.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" />
                        <path d="M12 7v4M10 9h4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" />
                    </svg>
                </span>
                <span class="ni-label">Create User</span>
                <span class="ni-tip">Create User</span>
            </a>
            <a class="nav-item" asp-controller="Admin" asp-action="ManageUser">
                <span class="ni-icon">
                    <svg width="15" height="15" viewBox="0 0 16 16" fill="none">
                        <path d="M1 13c0-3 2.686-4.5 6-4.5s6 1.5 6 4.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" />
                        <circle cx="6" cy="5" r="3" stroke="currentColor" stroke-width="1.5" />
                        <path d="M13 7a2 2 0 010 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" />
                    </svg>
                </span>
                <span class="ni-label">Manage Users</span>
                <span class="ni-tip">Manage Users</span>
            </a>

            <div class="nav-section-label">Finance</div>
            <a class="nav-item" asp-controller="Admin" asp-action="Transaction">
                <span class="ni-icon">
                    <svg width="15" height="15" viewBox="0 0 16 16" fill="none">
                        <path d="M2 8h12M10 5l3 3-3 3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
                    </svg>
                </span>
                <span class="ni-label">Transactions</span>
                <span class="ni-tip">Transactions</span>
            </a>
            <a class="nav-item" asp-controller="Admin" asp-action="ManageAccounts">
                <span class="ni-icon">
                    <svg width="15" height="15" viewBox="0 0 16 16" fill="none">
                        <rect x="1" y="4" width="14" height="9" rx="1.5" stroke="currentColor" stroke-width="1.5" />
                        <path d="M4 8h2M7 8h1M10 8h2" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" />
                    </svg>
                </span>
                <span class="ni-label">Accounts</span>
                <span class="ni-tip">Accounts</span>
            </a>

            <div class="nav-section-label">System</div>
            <a class="nav-item" asp-controller="Admin" asp-action="Settings">
                <span class="ni-icon">
                    <svg width="15" height="15" viewBox="0 0 16 16" fill="none">
                        <circle cx="8" cy="8" r="2.5" stroke="currentColor" stroke-width="1.5" />
                        <path d="M8 1v2M8 13v2M1 8h2M13 8h2M3.22 3.22l1.42 1.42M11.36 11.36l1.42 1.42M3.22 12.78l1.42-1.42M11.36 4.64l1.42-1.42" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" />
                    </svg>
                </span>
                <span class="ni-label">Settings</span>
                <span class="ni-tip">Settings</span>
            </a>
            <a class="nav-item" asp-controller="Admin" asp-action="Reports">
                <span class="ni-icon">
                    <svg width="15" height="15" viewBox="0 0 16 16" fill="none">
                        <path d="M2 3h12v8H2zM5 14h6M8 11v3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
                    </svg>
                </span>
                <span class="ni-label">Reports</span>
                <span class="ni-tip">Reports</span>
            </a>

        </nav>

        <div class="sb-footer">
            <form asp-controller="Login" asp-action="Logout" method="post">
                <button type="submit" class="logout-btn">
                    <span class="lo-icon">
                        <svg width="14" height="14" viewBox="0 0 16 16" fill="none">
                            <path d="M6 2H3a1 1 0 00-1 1v10a1 1 0 001 1h3M11 11l3-3-3-3M14 8H6"
                                  stroke="#dc2626" stroke-width="1.5"
                                  stroke-linecap="round" stroke-linejoin="round" />
                        </svg>
                    </span>
                    <span class="lo-label">Logout</span>
                </button>
            </form>
        </div>

    </aside>
    <!-- ══════════ /SIDEBAR ══════════ -->
    <!-- ══════════ MAIN ══════════ -->
    <div class="main-wrapper" id="mainWrapper">

        <!-- Topbar -->
        <header class="topbar">
            <div class="topbar-left">
                <a class="breadcrumb-home" asp-controller="Admin" asp-action="Index">Dashboard</a>
                <span class="breadcrumb-sep">/</span>
                <span class="breadcrumb-current">Create User Account</span>
            </div>
            <div class="topbar-right">
                <a class="btn-topbar ghost" asp-controller="Admin" asp-action="ManageUser">
                    <svg width="13" height="13" viewBox="0 0 16 16" fill="none">
                        <circle cx="6" cy="5" r="3" stroke="currentColor" stroke-width="1.5" />
                        <path d="M1 13c0-3 2.686-4.5 6-4.5s6 1.5 6 4.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" />
                    </svg>
                    Manage Users
                </a>
                <form asp-controller="Login" asp-action="Logout" method="post" style="margin:0;">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn-topbar danger">
                        <svg width="13" height="13" viewBox="0 0 16 16" fill="none">
                            <path d="M6 2H3a1 1 0 00-1 1v10a1 1 0 001 1h3M11 11l3-3-3-3M14 8H6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
                        </svg>
                        Logout
                    </button>
                </form>
            </div>
        </header>

        <!-- Page Content -->
        <div class="page-content">

            <!-- Page Header -->
            <div class="page-header">
                <div>
                    <div class="page-badge">
                        <svg width="10" height="10" viewBox="0 0 12 12" fill="none">
                            <circle cx="6" cy="6" r="5" stroke="currentColor" stroke-width="1.5" />
                            <path d="M4 6l1.5 1.5L8 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
                        </svg>
                        New Registration
                    </div>
                    <h1 class="page-title">Create User Account</h1>
                    <p class="page-subtitle">Register a new user and configure their banking profile</p>
                </div>

                <!-- Step indicator -->
                <div class="steps">
                    <div class="step-item active">
                        <div class="step-num">1</div>
                        <span>User Info</span>
                    </div>
                    <div class="step-connector"></div>
                    <div class="step-item">
                        <div class="step-num">2</div>
                        <span>Account</span>
                    </div>
                    <div class="step-connector"></div>
                    <div class="step-item">
                        <div class="step-num">3</div>
                        <span>Review</span>
                    </div>
                </div>
            </div>

            <!-- Server-side validation summary -->
            @if (!ViewData.ModelState.IsValid)
            {
                <div class="validation-box">
                    <div asp-validation-summary="All" class="text-danger"></div>
                </div>
            }

            <!-- ══ FORM ══ -->
            <form asp-controller="Admin" asp-action="CreateUserAccount" method="post">
                @Html.AntiForgeryToken()

                <div class="form-grid">

                    <!-- ── LEFT: User Information ── -->
                    <div class="form-card">
                        <div class="card-header">
                            <div class="card-icon icon-blue">
                                <svg width="18" height="18" viewBox="0 0 20 20" fill="none">
                                    <circle cx="10" cy="6" r="4" stroke="currentColor" stroke-width="1.7" />
                                    <path d="M3 18c0-3.866 3.134-7 7-7s7 3.134 7 7" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" />
                                </svg>
                            </div>
                            <div>
                                <div class="card-title">User Information</div>
                                <div class="card-desc">Personal credentials and login details</div>
                            </div>
                        </div>

                        <div class="fields-stack">

                            <!-- Full Name -->
                            <div class="field-group">
                                <label class="field-label" asp-for="FullName">Full Name</label>
                                <div class="input-wrap">
                                    <span class="input-prefix">
                                        <svg width="14" height="14" viewBox="0 0 16 16" fill="none">
                                            <circle cx="8" cy="5" r="3" stroke="currentColor" stroke-width="1.4" />
                                            <path d="M2 14c0-3 2.686-4.5 6-4.5s6 1.5 6 4.5" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" />
                                        </svg>
                                    </span>
                                    <input asp-for="FullName" class="inp" placeholder="e.g. Ahmed Khan" autocomplete="off" />
                                </div>
                                <span asp-validation-for="FullName" class="field-err"></span>
                            </div>

                            <!-- Email -->
                            <div class="field-group">
                                <label class="field-label" asp-for="Email">Email Address</label>
                                <div class="input-wrap">
                                    <span class="input-prefix">
                                        <svg width="14" height="14" viewBox="0 0 16 16" fill="none">
                                            <rect x="2" y="4" width="12" height="9" rx="1.5" stroke="currentColor" stroke-width="1.4" />
                                            <path d="M2 6l6 4 6-4" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" />
                                        </svg>
                                    </span>
                                    <input asp-for="Email" class="inp" placeholder="e.g. ahmed@email.com" autocomplete="off" />
                                </div>
                                <span asp-validation-for="Email" class="field-err"></span>
                            </div>

                            <!-- Password -->
                            <div class="field-group">
                                <label class="field-label" asp-for="Password">Password</label>
                                <div class="input-wrap">
                                    <span class="input-prefix">
                                        <svg width="14" height="14" viewBox="0 0 16 16" fill="none">
                                            <rect x="3" y="7" width="10" height="7" rx="1.5" stroke="currentColor" stroke-width="1.4" />
                                            <path d="M5 7V5a3 3 0 016 0v2" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" />
                                            <circle cx="8" cy="10.5" r="1" fill="currentColor" />
                                        </svg>
                                    </span>
                                    <input asp-for="Password" id="pwInput" type="password" class="inp" placeholder="Min. 8 characters" autocomplete="new-password" />
                                    <button type="button" class="pw-toggle" onclick="togglePw()" aria-label="Toggle password visibility">
                                        <svg id="eye-show" width="14" height="14" viewBox="0 0 16 16" fill="none">
                                            <ellipse cx="8" cy="8" rx="6" ry="4" stroke="currentColor" stroke-width="1.4" />
                                            <circle cx="8" cy="8" r="2" stroke="currentColor" stroke-width="1.4" />
                                        </svg>
                                        <svg id="eye-hide" width="14" height="14" viewBox="0 0 16 16" fill="none" style="display:none;">
                                            <path d="M2 2l12 12M6.5 6.5A2 2 0 0010 10M4 4.5C2.8 5.5 2 7 2 8s2 4 6 4a8 8 0 003-.6M7 4.1A6 6 0 0114 8c-.3.8-.9 1.7-1.7 2.4" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" />
                                        </svg>
                                    </button>
                                </div>
                                <span asp-validation-for="Password" class="field-err"></span>
                            </div>

                        </div>
                    </div>
                    <!-- ── /LEFT ── -->
                    <!-- ── RIGHT: Account Information ── -->
                    <div class="form-card">
                        <div class="card-header">
                            <div class="card-icon icon-teal">
                                <svg width="18" height="18" viewBox="0 0 20 20" fill="none">
                                    <rect x="2" y="5" width="16" height="12" rx="2" stroke="currentColor" stroke-width="1.7" />
                                    <path d="M6 5V4a4 4 0 018 0v1" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" />
                                    <path d="M7 11h2M11 11h2M7 14h2M11 14h2" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" />
                                </svg>
                            </div>
                            <div>
                                <div class="card-title">Account Information</div>
                                <div class="card-desc">Banking account configuration and settings</div>
                            </div>
                        </div>

                        <div class="fields-2col">

                            <!-- Account Number -->
                            <div class="field-group col-span-2">
                                <label class="field-label" asp-for="AccountNumber">Account Number</label>
                                <div class="input-wrap">
                                    <span class="input-prefix">
                                        <svg width="14" height="14" viewBox="0 0 16 16" fill="none">
                                            <rect x="1" y="4" width="14" height="9" rx="1.5" stroke="currentColor" stroke-width="1.4" />
                                            <path d="M4 8h2M7 8h1M10 8h2" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" />
                                        </svg>
                                    </span>
                                    <input asp-for="AccountNumber" class="inp" placeholder="e.g. 1001234567" autocomplete="off" />
                                </div>
                                <span asp-validation-for="AccountNumber" class="field-err"></span>
                            </div>

                            <!-- Account Type -->
                            <div class="field-group col-span-2">
                                <label class="field-label" asp-for="AccountType">Account Type</label>
                                <div class="input-wrap select-wrap">
                                    <span class="input-prefix">
                                        <svg width="14" height="14" viewBox="0 0 16 16" fill="none">
                                            <path d="M2 4h12M2 8h8M2 12h5" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" />
                                        </svg>
                                    </span>
                                    <select asp-for="AccountType" class="inp">
                                        <option value="">Select account type</option>
                                        <option value="Savings">Savings</option>
                                        <option value="Current">Current</option>
                                        <option value="Fixed">Fixed Deposit</option>
                                    </select>
                                </div>
                                <span asp-validation-for="AccountType" class="field-err"></span>
                            </div>

                            <!-- Initial Balance -->
                            <div class="field-group">
                                <label class="field-label" asp-for="Balance">Initial Balance</label>
                                <div class="input-wrap">
                                    <span class="input-prefix text-prefix">$</span>
                                    <input asp-for="Balance" class="inp" placeholder="0.00" autocomplete="off" />
                                </div>
                                <span asp-validation-for="Balance" class="field-err"></span>
                            </div>

                            <!-- Interest Rate -->
                            <div class="field-group">
                                <label class="field-label" asp-for="InterestRate">Interest Rate</label>
                                <div class="input-wrap">
                                    <span class="input-prefix">
                                        <svg width="14" height="14" viewBox="0 0 16 16" fill="none">
                                            <circle cx="5" cy="5" r="2" stroke="currentColor" stroke-width="1.4" />
                                            <circle cx="11" cy="11" r="2" stroke="currentColor" stroke-width="1.4" />
                                            <path d="M13 3L3 13" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" />
                                        </svg>
                                    </span>
                                    <input asp-for="InterestRate" class="inp" placeholder="e.g. 3.5" autocomplete="off" />
                                    <span class="input-suffix">%</span>
                                </div>
                                <span asp-validation-for="InterestRate" class="field-err"></span>
                            </div>

                        </div>
                    </div>
                    <!-- ── /RIGHT ── -->

                </div>
                <!-- /form-grid -->
                <!-- Action bar -->
                <div class="form-actions">
                    <p class="form-actions-note">All fields marked are <span>required</span></p>
                    <div class="form-actions-right">
                        <button type="reset" class="btn btn-secondary">
                            <svg width="13" height="13" viewBox="0 0 14 14" fill="none">
                                <path d="M2 7a5 5 0 109.9-1M2 7V4m0 3H5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
                            </svg>
                            Clear Form
                        </button>
                        <button type="submit" class="btn btn-primary">
                            <svg width="15" height="15" viewBox="0 0 16 16" fill="none">
                                <circle cx="8" cy="8" r="6" stroke="currentColor" stroke-width="1.5" />
                                <path d="M5.5 8l2 2 3-3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
                            </svg>
                            Create Account
                        </button>
                    </div>
                </div>

            </form>

        </div>
        <!-- /page-content -->

    </div>
    <!-- ══════════ /MAIN ══════════ -->


    <script>
        /* ── Sidebar toggle ── */
        document.getElementById('sbToggle').addEventListener('click', function () {
            const sidebar     = document.getElementById('sidebar');
            const mainWrapper = document.getElementById('mainWrapper');
            sidebar.classList.toggle('collapsed');
            mainWrapper.classList.toggle('collapsed');
            localStorage.setItem('sb-collapsed', sidebar.classList.contains('collapsed'));
        });

        /* Restore sidebar state */
        window.addEventListener('DOMContentLoaded', function () {
            if (localStorage.getItem('sb-collapsed') === 'true') {
                document.getElementById('sidebar').classList.add('collapsed');
                document.getElementById('mainWrapper').classList.add('collapsed');
            }
        });

        /* ── Password visibility toggle ── */
        function togglePw() {
            const input   = document.getElementById('pwInput');
            const eyeShow = document.getElementById('eye-show');
            const eyeHide = document.getElementById('eye-hide');
            const isHidden = input.type === 'password';

            input.type         = isHidden ? 'text' : 'password';
            eyeShow.style.display = isHidden ? 'none'  : 'block';
            eyeHide.style.display = isHidden ? 'block' : 'none';
        }

        /* ── Toastr notifications ── */
        $(document).ready(function () {
            toastr.options = {
                positionClass:    'toast-top-right',
                timeOut:          '3500',
                closeButton:      true,
                progressBar:      true,
                preventDuplicates: true,
                showMethod:       'slideDown',
                hideMethod:       'slideUp'
            };

            var successMsg = '@TempData["SuccessMessage"]';
            var errorMsg   = '@TempData["ErrorMessage"]';

            if (successMsg && successMsg.trim() !== '' && successMsg !== 'null') {
                toastr.success(successMsg);
            }
            if (errorMsg && errorMsg.trim() !== '' && errorMsg !== 'null') {
                toastr.error(errorMsg);
            }
        });
    </script>

</body>
</html>