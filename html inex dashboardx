@model BankingSystemweb.ViewModels.CreateUserAccountVM
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Dashboard — SecureBank Admin</title>
    <link rel="stylesheet" href="~/css/Admin.css" />
</head>
<body>

    <!-- Mobile overlay -->
    <div class="sb-overlay" id="sbOverlay"></div>

    <div class="admin-layout">

        <!-- ════════════ SIDEBAR ════════════ -->
        <aside class="sidebar" id="sidebar">

            <!-- Brand + Toggle -->
            <div class="sb-brand">
                <div class="brand-mark">
                    <!-- Shield / lock mark -->
                    <svg width="18" height="18" viewBox="0 0 20 20" fill="none">
                        <path d="M10 2L3 5v5c0 4.418 3.134 7.979 7 8 3.866-.021 7-3.582 7-8V5L10 2z"
                              fill="white" fill-opacity=".9"/>
                        <rect x="8.5" y="9" width="3" height="4" rx="1" fill="#2563eb"/>
                        <circle cx="10" cy="9" r="1.5" fill="#2563eb"/>
                    </svg>
                </div>
                <span class="brand-text">SecureBank</span>
                <div class="sb-toggle" id="sbToggle">
                    <svg width="10" height="10" viewBox="0 0 12 12" fill="none">
                        <path d="M7.5 2L3.5 6L7.5 10" stroke="#64748b" stroke-width="1.8"
                              stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                </div>
            </div>

            <nav class="sb-nav">
                <!-- Overview -->
                <div class="nav-sec">Overview</div>
                <a class="nav-item active" href="#">
                    <span class="ni-icon">
                        <svg width="15" height="15" viewBox="0 0 16 16" fill="none">
                            <rect x="1" y="1" width="6" height="6" rx="1.5" stroke="currentColor" stroke-width="1.5"/>
                            <rect x="9" y="1" width="6" height="6" rx="1.5" stroke="currentColor" stroke-width="1.5"/>
                            <rect x="1" y="9" width="6" height="6" rx="1.5" stroke="currentColor" stroke-width="1.5"/>
                            <rect x="9" y="9" width="6" height="6" rx="1.5" stroke="currentColor" stroke-width="1.5"/>
                        </svg>
                    </span>
                    <span class="ni-label">Dashboard</span>
                    <span class="ni-tip">Dashboard</span>
                </a>

                <!-- Users -->
                <div class="nav-sec">Users</div>
                <a class="nav-item" href="#">
                    <span class="ni-icon">
                        <svg width="15" height="15" viewBox="0 0 16 16" fill="none">
                            <circle cx="7" cy="5" r="3" stroke="currentColor" stroke-width="1.5"/>
                            <path d="M1 13c0-3 2.686-4.5 6-4.5s6 1.5 6 4.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                            <path d="M12 7v4M10 9h4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                        </svg>
                    </span>
                    <span class="ni-label">Create User</span>
                    <span class="ni-tip">Create User</span>
                </a>
                <a class="nav-item" href="#">
                    <span class="ni-icon">
                        <svg width="15" height="15" viewBox="0 0 16 16" fill="none">
                            <path d="M1 13c0-3 2.686-4.5 6-4.5s6 1.5 6 4.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                            <circle cx="6" cy="5" r="3" stroke="currentColor" stroke-width="1.5"/>
                            <path d="M13 7a2 2 0 010 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                        </svg>
                    </span>
                    <span class="ni-label">Manage Users</span>
                    <span class="ni-tip">Manage Users</span>
                </a>

                <!-- Finance -->
                <div class="nav-sec">Finance</div>
                <a class="nav-item" href="#">
                    <span class="ni-icon">
                        <svg width="15" height="15" viewBox="0 0 16 16" fill="none">
                            <path d="M2 8h12M10 5l3 3-3 3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                        </svg>
                    </span>
                    <span class="ni-label">Transactions</span>
                    <span class="ni-tip">Transactions</span>
                </a>
                <a class="nav-item" href="#">
                    <span class="ni-icon">
                        <svg width="15" height="15" viewBox="0 0 16 16" fill="none">
                            <rect x="1" y="4" width="14" height="9" rx="1.5" stroke="currentColor" stroke-width="1.5"/>
                            <path d="M4 8h2M7 8h1M10 8h2" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/>
                        </svg>
                    </span>
                    <span class="ni-label">Accounts</span>
                    <span class="ni-tip">Accounts</span>
                </a>

                <!-- System -->
                <div class="nav-sec">System</div>
                <a class="nav-item" href="#">
                    <span class="ni-icon">
                        <svg width="15" height="15" viewBox="0 0 16 16" fill="none">
                            <circle cx="8" cy="8" r="2.5" stroke="currentColor" stroke-width="1.5"/>
                            <path d="M8 1v2M8 13v2M1 8h2M13 8h2M3.22 3.22l1.42 1.42M11.36 11.36l1.42 1.42M3.22 12.78l1.42-1.42M11.36 4.64l1.42-1.42"
                                  stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                        </svg>
                    </span>
                    <span class="ni-label">Settings</span>
                    <span class="ni-tip">Settings</span>
                </a>
                <a class="nav-item" href="#">
                    <span class="ni-icon">
                        <svg width="15" height="15" viewBox="0 0 16 16" fill="none">
                            <path d="M2 3h12v8H2zM5 14h6M8 11v3"
                                  stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                        </svg>
                    </span>
                    <span class="ni-label">Reports</span>
                    <span class="ni-tip">Reports</span>
                </a>
            </nav>

            <div class="sb-footer">
                <button class="logout-btn">
                    <span class="lo-icon">
                        <svg width="14" height="14" viewBox="0 0 16 16" fill="none">
                            <path d="M6 2H3a1 1 0 00-1 1v10a1 1 0 001 1h3M11 11l3-3-3-3M14 8H6"
                                  stroke="#dc2626" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                        </svg>
                    </span>
                    <span class="lo-label">Logout</span>
                </button>
            </div>
        </aside>
        <!-- ════════════ /SIDEBAR ════════════ -->

        <!-- ════════════ MAIN ════════════ -->
        <main class="main-content" id="mainContent">

            <!-- ── TOPBAR ── -->
            <div class="topbar">
                <div class="topbar-left">
                    <button class="mobile-btn" id="mobileBtn">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none"
                             stroke="currentColor" stroke-width="2.2" stroke-linecap="round">
                            <line x1="3" y1="6" x2="21" y2="6"/>
                            <line x1="3" y1="12" x2="21" y2="12"/>
                            <line x1="3" y1="18" x2="21" y2="18"/>
                        </svg>
                    </button>
                    <div class="topbar-title">
                        <h1>Dashboard Overview</h1>
                        <p>Welcome back, Admin @ViewData["AdminName"]</p>
                    </div>
                </div>
                <div class="topbar-right">
                    <button class="t-icon-btn" title="Notifications">
                        <svg width="16" height="16" viewBox="0 0 20 20" fill="none">
                            <path d="M10 2a6 6 0 00-6 6v3l-1.5 2H17.5L16 11V8a6 6 0 00-6-6z"
                                  stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/>
                            <path d="M8.5 16a1.5 1.5 0 003 0" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/>
                        </svg>
                        <span class="notif-dot"></span>
                    </button>
                    <div class="admin-chip">
                        <div class="admin-avatar">
                            @(ViewData["AdminName"]?.ToString() is string n ? GetInitials(n) : "AD")
                        </div>
                        <span class="admin-name">@ViewData["AdminName"]</span>
                    </div>
                </div>
            </div>

            <!-- ── PAGE BODY ── -->
            <div class="page-body">

                <!-- ── STAT CARDS ── -->
                <div class="stats-grid">

                    <div class="stat-card card-blue">
                        <div class="stat-icon">
                            <svg width="22" height="22" viewBox="0 0 24 24" fill="none">
                                <path d="M17 21v-2a4 4 0 00-4-4H7a4 4 0 00-4 4v2" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
                                <circle cx="9" cy="7" r="4" stroke="currentColor" stroke-width="1.8"/>
                                <path d="M23 21v-2a4 4 0 00-3-3.87M16 3.13a4 4 0 010 7.75" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
                            </svg>
                        </div>
                        <div class="stat-body">
                            <p class="stat-label">Total Users</p>
                            <p class="stat-number">@ViewData["TotalUsers"]</p>
                            <span class="stat-badge up">&#9650; 12%</span>
                        </div>
                    </div>

                    <div class="stat-card card-green">
                        <div class="stat-icon">
                            <svg width="22" height="22" viewBox="0 0 24 24" fill="none">
                                <rect x="2" y="7" width="20" height="14" rx="2" stroke="currentColor" stroke-width="1.8"/>
                                <path d="M16 7V5a2 2 0 00-2-2h-4a2 2 0 00-2 2v2" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
                                <line x1="12" y1="12" x2="12" y2="16" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
                                <line x1="10" y1="14" x2="14" y2="14" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
                            </svg>
                        </div>
                        <div class="stat-body">
                            <p class="stat-label">Active Accounts</p>
                            <p class="stat-number">@ViewData["TotalActiveUsers"]</p>
                            <span class="stat-badge up">&#9650; 8%</span>
                        </div>
                    </div>

                    <div class="stat-card card-purple">
                        <div class="stat-icon">
                            <svg width="22" height="22" viewBox="0 0 24 24" fill="none">
                                <path d="M7 16l3-8 3 8M9.5 12h3" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
                                <circle cx="17" cy="8" r="2" stroke="currentColor" stroke-width="1.8"/>
                                <path d="M3 12h2M19 12h2M12 3v2M12 19v2" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
                            </svg>
                        </div>
                        <div class="stat-body">
                            <p class="stat-label">Transactions Today</p>
                            <p class="stat-number">@ViewData["TotalTransactions"]</p>
                            <span class="stat-badge up">&#9650; 5%</span>
                        </div>
                    </div>

                    <div class="stat-card card-orange">
                        <div class="stat-icon">
                            <svg width="22" height="22" viewBox="0 0 24 24" fill="none">
                                <circle cx="12" cy="12" r="9" stroke="currentColor" stroke-width="1.8"/>
                                <path d="M12 7v1m0 8v1M9.5 9.5C9.5 8.4 10.6 8 12 8s2.5.4 2.5 1.5S13.4 11 12 12s-2.5 1-2.5 2.5S10.6 16 12 16s2.5-.4 2.5-1.5"
                                      stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
                            </svg>
                        </div>
                        <div class="stat-body">
                            <p class="stat-label">Total Balance</p>
                            <p class="stat-number">@ViewData["AdminBalance"]</p>
                            <span class="stat-badge up">&#9650; 3%</span>
                        </div>
                    </div>

                </div>
                <!-- /stats-grid -->

                <!-- ── QUICK ACTIONS ── -->
                <div>
                    <div class="sec-hdr">
                        <div>
                            <p class="sec-title">Quick Actions</p>
                            <p class="sec-sub">Navigate to key features</p>
                        </div>
                    </div>

                    <div class="action-grid">

                        <!-- 1. Create User -->
                        <a class="action-card ac-blue"
                           asp-controller="Admin" asp-action="CreateUserAccount">
                            <div class="ac-icon">
                                <svg viewBox="0 0 24 24" fill="none">
                                    <path d="M16 21v-2a4 4 0 00-4-4H6a4 4 0 00-4 4v2" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
                                    <circle cx="9" cy="7" r="4" stroke="currentColor" stroke-width="1.8"/>
                                    <line x1="19" y1="8" x2="19" y2="14" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
                                    <line x1="16" y1="11" x2="22" y2="11" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
                                </svg>
                            </div>
                            <div class="ac-text">
                                <h3>Create User</h3>
                                <p>Add new user to system</p>
                            </div>
                        </a>

                        <!-- 2. Create Account -->
                        <a class="action-card ac-green"
                           asp-controller="Admin" asp-action="CreateUserAccount">
                            <div class="ac-icon">
                                <svg viewBox="0 0 24 24" fill="none">
                                    <rect x="3" y="6" width="18" height="13" rx="2" stroke="currentColor" stroke-width="1.8"/>
                                    <path d="M3 10h18" stroke="currentColor" stroke-width="1.8"/>
                                    <path d="M7 15h2M13 15h4" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
                                </svg>
                            </div>
                            <div class="ac-text">
                                <h3>Create Account</h3>
                                <p>Open new bank account</p>
                            </div>
                        </a>

                        <!-- 3. Make Transaction -->
                        <a class="action-card ac-purple"
                           asp-controller="Admin" asp-action="transaction">
                            <div class="ac-icon">
                                <svg viewBox="0 0 24 24" fill="none">
                                    <path d="M7 16l-4-4 4-4M17 8l4 4-4 4" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
                                    <line x1="3" y1="12" x2="21" y2="12" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
                                </svg>
                            </div>
                            <div class="ac-text">
                                <h3>Make Transaction</h3>
                                <p>Process fund transfer</p>
                            </div>
                        </a>

                        <!-- 4. Manage Users -->
                        <a class="action-card ac-orange"
                           asp-controller="Admin" asp-action="ManageUser">
                            <div class="ac-icon">
                                <svg viewBox="0 0 24 24" fill="none">
                                    <path d="M17 21v-2a4 4 0 00-4-4H7a4 4 0 00-4 4v2" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
                                    <circle cx="9" cy="7" r="4" stroke="currentColor" stroke-width="1.8"/>
                                    <path d="M23 21v-2a4 4 0 00-3-3.87M16 3.13a4 4 0 010 7.75" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
                                </svg>
                            </div>
                            <div class="ac-text">
                                <h3>Manage Users</h3>
                                <p>View and edit users</p>
                            </div>
                        </a>

                        <!-- 5. Manage Accounts -->
                        <a class="action-card ac-teal"
                           asp-controller="Admin" asp-action="ManageAccounts">
                            <div class="ac-icon">
                                <svg viewBox="0 0 24 24" fill="none">
                                    <path d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
                                    <rect x="9" y="3" width="6" height="4" rx="1" stroke="currentColor" stroke-width="1.8"/>
                                    <path d="M9 12h6M9 16h4" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
                                </svg>
                            </div>
                            <div class="ac-text">
                                <h3>Manage Accounts</h3>
                                <p>View all bank accounts</p>
                            </div>
                        </a>

                        <!-- 6. Reports -->
                        <a class="action-card ac-red" href="report.html">
                            <div class="ac-icon">
                                <svg viewBox="0 0 24 24" fill="none">
                                    <polyline points="22 12 18 12 15 21 9 3 6 12 2 12" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
                                </svg>
                            </div>
                            <div class="ac-text">
                                <h3>Reports</h3>
                                <p>View analytics &amp; reports</p>
                            </div>
                        </a>

                    </div>
                </div>
                <!-- /quick actions -->

                <!-- ── BOTTOM ROW ── -->
                <div class="bottom-row">

                    <!-- Recent Activity -->
                    <div class="panel">
                        <div class="sec-hdr">
                            <div>
                                <p class="sec-title">Recent Activity</p>
                                <p class="sec-sub">Latest system events</p>
                            </div>
                            <a class="sec-link" href="#">View all</a>
                        </div>
                        <div class="activity-list">

                            <div class="activity-item">
                                <div class="ai-dot blue">U</div>
                                <div class="ai-body">
                                    <h4>User Account Created</h4>
                                    <p>John Doe — john.doe@securebank.com</p>
                                    <span class="ai-time">5 minutes ago</span>
                                </div>
                            </div>

                            <div class="activity-item">
                                <div class="ai-dot green">A</div>
                                <div class="ai-body">
                                    <h4>Savings Account Opened</h4>
                                    <p>Account #1234567890 — Initial deposit processed</p>
                                    <span class="ai-time">22 minutes ago</span>
                                </div>
                            </div>

                            <div class="activity-item">
                                <div class="ai-dot purple">T</div>
                                <div class="ai-body">
                                    <h4>Transfer Completed</h4>
                                    <p>$5,000.00 — Account #9876543210</p>
                                    <span class="ai-time">1 hour ago</span>
                                </div>
                            </div>

                            <div class="activity-item">
                                <div class="ai-dot orange">E</div>
                                <div class="ai-body">
                                    <h4>Profile Information Updated</h4>
                                    <p>Jane Smith — Contact details modified</p>
                                    <span class="ai-time">2 hours 15 min ago</span>
                                </div>
                            </div>

                            <div class="activity-item">
                                <div class="ai-dot teal">D</div>
                                <div class="ai-body">
                                    <h4>Deposit Received</h4>
                                    <p>$10,000.00 — Account #5678901234</p>
                                    <span class="ai-time">4 hours 30 min ago</span>
                                </div>
                            </div>

                        </div>
                    </div>
                    <!-- /recent activity -->

                    <!-- System Summary -->
                    <div class="panel">
                        <div class="sec-hdr" style="margin-bottom:18px">
                            <div>
                                <p class="sec-title">System Summary</p>
                                <p class="sec-sub">Live overview</p>
                            </div>
                        </div>

                        <div class="sum-row">
                            <span class="sr-lbl"><span class="sr-dot g"></span>Active Users</span>
                            <span class="sr-val">@ViewData["TotalActiveUsers"]</span>
                        </div>
                        <div class="sum-row">
                            <span class="sr-lbl"><span class="sr-dot r"></span>Inactive Accounts</span>
                            <span class="sr-val">2</span>
                        </div>
                        <div class="sum-row">
                            <span class="sr-lbl"><span class="sr-dot a"></span>Pending Reviews</span>
                            <span class="sr-val">3</span>
                        </div>
                        <div class="sum-row">
                            <span class="sr-lbl"><span class="sr-dot g"></span>Today's Deposits</span>
                            <span class="sr-val">$24,500</span>
                        </div>
                        <div class="sum-row">
                            <span class="sr-lbl"><span class="sr-dot g"></span>Today's Withdrawals</span>
                            <span class="sr-val">$8,200</span>
                        </div>
                        <div class="sum-row">
                            <span class="sr-lbl"><span class="sr-dot r"></span>Failed Transactions</span>
                            <span class="sr-val">1</span>
                        </div>

                    </div>
                    <!-- /system summary -->

                </div>
                <!-- /bottom-row -->

            </div>
            <!-- /page-body -->

        </main>
        <!-- ════════════ /MAIN ════════════ -->

    </div>
    <!-- /admin-layout -->

    <script>
        /* ── Desktop: collapse/expand sidebar ── */
        const sidebar     = document.getElementById('sidebar');
        const mainContent = document.getElementById('mainContent');
        const sbToggle    = document.getElementById('sbToggle');
        const sbOverlay   = document.getElementById('sbOverlay');
        const mobileBtn   = document.getElementById('mobileBtn');

        let isCollapsed = false;

        sbToggle.addEventListener('click', () => {
            isCollapsed = !isCollapsed;
            sidebar.classList.toggle('collapsed', isCollapsed);
            mainContent.classList.toggle('wide', isCollapsed);
        });

        /* ── Mobile: open overlay ── */
        mobileBtn.addEventListener('click', () => {
            sidebar.classList.add('mobile-open');
            sbOverlay.classList.add('visible');
        });
        sbOverlay.addEventListener('click', () => {
            sidebar.classList.remove('mobile-open');
            sbOverlay.classList.remove('visible');
        });

        /* ── Active nav highlight based on current URL ── */
        const path = window.location.pathname;
        document.querySelectorAll('.nav-item').forEach(el => {
            const href = el.getAttribute('href') || '';
            if (href && path.includes(href.split('?')[0])) {
                document.querySelectorAll('.nav-item').forEach(i => i.classList.remove('active'));
                el.classList.add('active');
            }
        });
    </script>

    @functions {
        public string GetInitials(string fullName)
        {
            if (string.IsNullOrWhiteSpace(fullName)) return "AD";
            var words = fullName.Split(' ', System.StringSplitOptions.RemoveEmptyEntries);
            char first  = words.Length > 0 ? words[0][0] : 'A';
            char second = words.Length > 1 ? words[1][0] : 'D';
            return $"{char.ToUpper(first)}{char.ToUpper(second)}";
        }
    }

</body>
</html>
